# IAS OAuth Credentials (for authentication with deployed agent)
IAS_OAUTH_URL=https://<your-tenant>.accounts400.ondemand.com/oauth2/token
IAS_CLIENT_ID=<your-client-id>
IAS_CLIENT_SECRET=<your-client-secret>

# Deployed Agent URL (from GitHub Actions deployment logs)
AGENT_URL=https://<agent-name>.<cluster-id>.stage.kyma.ondemand.com
