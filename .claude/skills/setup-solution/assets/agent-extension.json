{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Extension Asset",
  "description": "Schema for agent extension asset definition",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "type", "sourceRoot"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "asset.sap/v1",
      "description": "API version"
    },
    "kind": {
      "type": "string",
      "const": "Asset",
      "description": "Resource type, must be 'Asset'"
    },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Identifying name for the asset",
          "pattern": "^[a-z0-9]([-a-z0-9]{0,61}[a-z0-9])?$"
        },
        "version": {
          "type": "string",
          "description": "Semantic version of this asset",
          "default": "1.0.0"
        }
      }
    },
    "type": {
      "type": "string",
      "const": "agent-extension",
      "description": "Asset type"
    },
    "sourceRoot": {
      "type": "string",
      "description": "Root directory where Agent Extension files are located",
      "default": "agent-extensions"
    },
    "provides": {
      "type": "object",
      "required": ["extensions"],
      "properties": {
        "extensions": {
          "type": "array",
          "description": "List of agent extensions provided by this asset",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["descriptorFile", "name"],
            "properties": {
              "descriptorFile": {
                "type": "string",
                "description": "Path to the extension descriptor YAML file",
                "pattern": "^.+\\.ya?ml$"
              },
              "name": {
                "type": "string",
                "description": "Human-readable extension name"
              }
            }
          }
        }
      }
    }
  }
}
